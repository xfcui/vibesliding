# VibeSliding Configuration Template
# Copy this file to .env and set your actual values
# Priority: --api-key > provider-specific env vars > .env

# Required: openrouter or volcengine (or set IMAGE_PROVIDER / --provider instead)
provider = openrouter

# Shared settings (apply before first [section])
max_concurrent = 36

# Optional global proxy URL ([openrouter] use_proxy must be true to use it)
# proxy = socks5://127.0.0.1:1080

[volcengine]
api_key = your-ark-api-key-here
img_model = doubao-seedream-5-0-260128
# Text model for outline (python -m src.outline.cli); img_model for render (python -m src.render.style.cli / src.render.cli)
txt_model = doubao-1-5-pro-32k-250115
# Direct connection by default; set use_proxy = true + proxy above to tunnel
use_proxy = false

[openrouter]
# Only used when provider = openrouter
api_key = your-openrouter-api-key-here
# Optional: Management API key for GET /credits — https://openrouter.ai/settings/management-keys
# management_api_key = sk-or-v1-mgmt-...
img_model = google/gemini-3-pro-image-preview
# Text model for outline (python -m src.outline.cli); img_model for render (python -m src.render.style.cli / src.render.cli)
txt_model = anthropic/claude-opus-4.6
use_proxy = true

[minimax]
# Required for present (python -m src.present.cli)
api_key = your-minimax-api-key-here
# TTS model: speech-2.8-hd (best quality) or speech-2.8-turbo (faster)
# tts_model = speech-2.8-hd
# System voice ID; ignored when --reference-audio or --voice-id is set
# tts_voice = Chinese (Mandarin)_Lyrical_Voice

[valyu]
# Only used for research (python -m src.research.cli)
api_key = your-valyu-api-key-here
# mode = standard
# Comma-separated datasource categories to restrict DeepResearch sources.
# Omit to search all sources. Valid: research, healthcare, patents, markets,
# company, economic, predictions, legal, politics, cybersecurity, transportation
# categories = research, healthcare
